  "components": {
    "schemas": {
      "AddRouteStopRequest": {
        "required": [
          "stopKey",
          "label",
          "addressLabel",
          "stopType",
          "sequenceNumber",
          "scheduledArrivalAt"
        ],
        "type": "object",
        "properties": {
          "stopKey": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "addressLabel": {
            "type": "string"
          },
          "stopType": {
            "type": "string"
          },
          "sequenceNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "scheduledArrivalAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "AssetDispatchabilityCheckRequest": {
        "type": "object",
        "properties": {
          "vehicleRefKey": {
            "type": [
              "null",
              "string"
            ]
          },
          "assetTag": {
            "type": [
              "null",
              "string"
            ]
