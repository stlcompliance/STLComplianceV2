# NexArr API base URL. Leave empty in local dev to use Vite proxy (/api -> localhost:5101).
VITE_NEXARR_API_URL=

# Optional: override proxy target when VITE_NEXARR_API_URL is empty (vite dev server only).
# VITE_NEXARR_PROXY_TARGET=http://localhost:5101

# Demo tenant for local login (matches NexArr PlatformSeeder).
VITE_DEMO_TENANT_ID=11111111-1111-1111-1111-111111111101
