{
  "Auth": {
    "Issuer": "stl-compliance-nexarr",
    "Audience": "stl-compliance-suite",
    "SigningKey": "local-dev-only-change-in-production-min-32",
    "AccessTokenMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "RecordArrFrontendOrigin": "http://localhost:5184"
  },
  "MalwareScanWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-malware-worker",
    "ScannerName": "external_malware_scanner",
    "PollIntervalSeconds": 60
  },
  "ObjectStoreReconciliationWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-object-store-worker",
    "PollIntervalSeconds": 300
  },
  "SignatureTrustServiceWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-signature-trust-worker",
    "PollIntervalSeconds": 300
  },
  "RedactionProviderWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-redaction-provider-worker",
    "PollIntervalSeconds": 300
  },
  "RedactionOverlayReviewWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-redaction-overlay-worker",
    "PollIntervalSeconds": 300
  },
  "BackupVerificationWorker": {
    "Enabled": false,
    "TenantIds": [],
    "RequestedByPersonId": "recordarr-backup-verification-worker",
    "DefaultRpoTargetMinutes": 60,
    "PollIntervalSeconds": 3600
  },
  "NexArr:BaseUrl": "http://localhost:5101",
  "AllowedHosts": "*"
}
